rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role (admin/donor), createdAt
    //
    // Collection: donations
    // Fields: amount, type, donorEmail, donorId, status, transactionId, createdAt
    //
    // Collection: students
    // Fields: name, story, imageUrl, isSponsored, sponsorId, createdAt
    //
    // Collection: content
    // Fields: type (blog/gallery), title, content, imageUrl, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "careersheraziit@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'donor'];
    }

    function isValidDonation(data) {
      return data.keys().hasAll(['amount', 'type', 'donorEmail', 'status', 'createdAt']) &&
             data.amount is number && data.amount > 0 &&
             data.type in ['one-time', 'monthly'] &&
             data.status in ['pending', 'completed', 'failed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'donor' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /donations/{donationId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.donorId == request.auth.uid);
      allow create: if isAuthenticated() && isValidDonation(request.resource.data);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /students/{studentId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    match /content/{contentId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
